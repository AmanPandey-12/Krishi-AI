# ============================================
# AgroAI - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to git
# ============================================

# --- AI / ML ---
# OpenRouter API — Get free key from https://openrouter.ai
# Used for: Disease detection, AI Copilot chat, Crop Picker recommendations
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- IMAGE HOSTING ---
# ImgBB API — Get free key from https://api.imgbb.com
# Used for: Profile photo upload, crop scan image storage
VITE_IMGBB_API_KEY=your_imgbb_api_key_here

# --- WEATHER ---
# OpenWeatherMap — Get free key from https://openweathermap.org/api
# Used for: Live weather dashboard, crop-specific alerts
# Free tier: 60 calls/minute — more than enough
VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here

# --- FIREBASE ---
# Get all values from: Firebase Console → Project Settings → General
# Project: agroai-e1212
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# --- UNUSED / RESERVED ---
# These keys are reserved for future features
# VITE_AGRO_API_KEY=reserved_for_future
# VITE_NVIDIA_API_KEY=reserved_for_future
